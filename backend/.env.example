# ──────────────────────────────────────────────
# 한국형 상세페이지 자동 생성 서비스 - 환경변수
# ──────────────────────────────────────────────

# AI API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/detailpage

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3 (이미지 저장용)
AWS_ACCESS_KEY=xxx
AWS_SECRET_KEY=xxx
AWS_REGION=ap-northeast-2
S3_BUCKET=detailpage-images

# App Settings
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Claude Model Settings
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# Image Processing
MAX_IMAGE_SIZE_MB=10
IMAGE_OUTPUT_WIDTH=860
IMAGE_QUALITY=90
