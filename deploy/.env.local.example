# Anthropic API Key (선택사항 - 없어도 템플릿 기반으로 동작)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API Key (선택사항 - DALL-E 편집/생성 fallback에 사용)
OPENAI_API_KEY=sk-xxx

# Unsplash Access Key (무료 - https://unsplash.com/developers 에서 발급)
UNSPLASH_ACCESS_KEY=xxx

# Pexels API Key (무료 - https://www.pexels.com/api/ 에서 발급)
PEXELS_API_KEY=xxx

# Remove.bg API Key (선택사항 - 누끼 추출에 사용, 없으면 원본 이미지 사용)
REMOVEBG_API_KEY=xxx
